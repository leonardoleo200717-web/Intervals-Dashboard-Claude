# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.

# Garmin Connect (for garmin_sync.py automated downloads)
GARMIN_EMAIL=user@email.com
GARMIN_PASSWORD=your-garmin-password

# AI chat providers — server-side only. Configure one or more; the chat
# panel lets you pick which model to ask from the ones you've set a key for.
# Anthropic (Claude):
ANTHROPIC_API_KEY=sk-ant-...
# DeepSeek (https://platform.deepseek.com):
DEEPSEEK_API_KEY=
# OpenAI (https://platform.openai.com):
OPENAI_API_KEY=
